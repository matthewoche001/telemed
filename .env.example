# OHMS — Environment Variables Template
# Copy this to .env and fill in real values

# Django
SECRET_KEY=django-insecure-change-this-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_NAME=ohms_db
DB_USER=ohms_user
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=3306
